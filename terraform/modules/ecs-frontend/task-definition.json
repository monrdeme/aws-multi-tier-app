[
    {
        "name": "aws-multi-tier-app-dev-frontend-container",
        "image": "",
        "cpu": 256,
        "memory": 512,
        "essential": true,
        "portMappings": [
            {
                "containerPort": 8000,
                "hostPort": 8000,
                "protocol": "tcp"
            }
        ],
        "environment": [],
        "logConfiguration": {
            "logDriver": "awslogs",
            "options": {
                "awslogs-group": "/ecs/aws-multi-tier-app-dev-frontend-app",
                "awslogs-region": "us-east-1",
                "awslogs-stream-prefix": "ecs-frontend"
            }
        }
    }
